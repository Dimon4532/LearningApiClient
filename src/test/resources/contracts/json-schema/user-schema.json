{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "User",
  "type": "object",
  "required": ["id", "name", "username", "email"],
  "properties": {
    "id":       { "type": "integer", "minimum": 1 },
    "name":     { "type": "string", "minLength": 1 },
    "username": { "type": "string", "minLength": 1 },
    "email":    { "type": "string", "format": "email" }
  }
}